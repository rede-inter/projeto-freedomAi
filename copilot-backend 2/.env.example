PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Auth
STUDIO_API_KEY=dev-secret-key-change-in-production

# Mock mode (true = usa dados em memoria, false = chama APIs reais)
USE_MOCK_APIS=true

# APIs externas (usadas somente quando USE_MOCK_APIS=false)
TICKETS_API_URL=https://api.tickets.exemplo.com
TICKETS_API_KEY=token-da-api-tickets
CUSTOMERS_API_URL=https://api.customers.exemplo.com
CUSTOMERS_API_KEY=token-da-api-customers

# Timeouts (ms)
API_TIMEOUT_MS=5000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
