    {
      "name": "Triage",
      "item": [
        {
          "name": "POST /v1/triage — outage critical → P1",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const d = pm.response.json().data;",
              "pm.test('P1 suggested', () => pm.expect(d.suggestedPriority).to.eql('P1'));",
              "pm.test('slaResponseHours = 1', () => pm.expect(d.slaResponseHours).to.eql(1));",
              "pm.test('has actions', () => pm.expect(d.recommendedActions.length).to.be.above(0));",
              "pm.test('has summary', () => pm.expect(d.summary).to.include('CUST-001'));",
              "pm.test('has reason', () => pm.expect(d.priorityReason).to.be.a('string'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
