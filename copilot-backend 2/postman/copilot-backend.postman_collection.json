{
  "info": {
    "name": "Copiloto Operacional de Suporte",
    "description": "Coleção completa do backend. Inclui todos os endpoints, exemplos de erro e simulação de falhas.\n\nConfigurar a variável de ambiente `baseUrl` e `apiKey` antes de usar.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "copilot-backend-v1"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:3000" },
    { "key": "apiKey",        "value": "dev-secret-key-change-in-production" },
    { "key": "convId",        "value": "postman-conv-001" },
    { "key": "lastTicketId",  "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));",
              "pm.test('has uptime', () => pm.expect(pm.response.json().uptime).to.be.a('number'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health" }
          }
        },
        {
          "name": "GET /ready",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('ready true', () => pm.expect(pm.response.json().ready).to.be.true);"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/ready" }
          }
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "GET /v1/customer/CUST-001 (enterprise active)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('success true', () => pm.expect(b.success).to.be.true);",
              "pm.test('id correct', () => pm.expect(b.data.id).to.eql('CUST-001'));",
              "pm.test('email masked', () => pm.expect(b.data.email).to.include('***'));",
              "pm.test('cnpj masked', () => pm.expect(b.data.cnpj).to.include('**'));",
              "pm.test('no raw cnpj', () => pm.expect(b.data.cnpj).to.not.eql('12.345.678/0001-90'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" },
              { "key": "X-Conversation-Id", "value": "{{convId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/v1/customer/CUST-001" }
          }
        },
        {
          "name": "GET /v1/customer/CUST-004 (suspended)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200 — query still works', () => pm.response.to.have.status(200));",
              "pm.test('status suspended', () => pm.expect(pm.response.json().data.status).to.eql('suspended'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/v1/customer/CUST-004" }
          }
        },
        {
          "name": "GET /v1/customer/CUST-999 → 404",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));",
              "pm.test('code NOT_FOUND', () => pm.expect(pm.response.json().error.code).to.eql('CUSTOMER_NOT_FOUND'));",
              "pm.test('has requestId', () => pm.expect(pm.response.json().error.requestId).to.be.a('string'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
            "url": { "raw": "{{baseUrl}}/v1/customer/CUST-999" }
          }
        },
        {
          "name": "GET /v1/customer/:id → 401 (no key)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('code UNAUTHORIZED', () => pm.expect(pm.response.json().error.code).to.eql('UNAUTHORIZED'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/customer/CUST-001" }
          }
        },
        {
          "name": "GET /v1/customer/:id → 400 (invalid id format)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('code INVALID_CUSTOMER_ID', () => pm.expect(pm.response.json().error.code).to.eql('INVALID_CUSTOMER_ID'));"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
            "url": { "raw": "{{baseUrl}}/v1/customer/invalid-format" }
          }
        }
      ]
    },
