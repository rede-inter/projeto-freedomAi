            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const d = pm.response.json().data;",
              "pm.test('priority P1', () => pm.expect(d.priority).to.eql('P1'));",
              "pm.test('auto assigned', () => pm.expect(d.priorityAutoAssigned).to.be.true);",
              "pm.test('not overridden', () => pm.expect(d.priorityOverridden).to.be.false);",
              "pm.test('status open', () => pm.expect(d.status).to.eql('open'));",
              "pm.test('has slaDeadline', () => pm.expect(d.slaDeadline).to.be.a('string'));",
              "pm.test('no _hash', () => pm.expect(d._hash).to.be.undefined);",
              "pm.collectionVariables.set('lastTicketId', d.id);",
              "pm.test('message present', () => pm.expect(d.message).to.eql('Ticket criado com sucesso.'));"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{apiKey}}" },
              { "key": "Content-Type", "value": "application/json" },
